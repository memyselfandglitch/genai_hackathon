# Copy to backend/.env and fill in. Never commit .env.
# Lines are documented in README (Hackathon / Live MCP section).

# GOOGLE_API_KEY=          # or GEMINI_API_KEY= (same Studio key)
# GEMINI_MODEL=gemini-flash-latest
# APP_NAME=agents
# DEBUG=false
# DATABASE_URL=sqlite+aiosqlite:///./exec_assistant.db
# DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/DB?ssl=require
# MCP_BIGQUERY_SSE_URL=
# MCP_MAPS_SSE_URL=
# MCP_CALENDAR_SSE_URL=
# MCP_TASKS_SSE_URL=
# GOOGLE_WORKSPACE_ACCESS_TOKEN=
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_TASKS_LIST_ID=@default
